# Database Connection (Supabase PostgreSQL)
SUPABASE_URL="postgresql://user:password@host:port/dbname"

# NVIDIA NIM API Key — get yours at https://build.nvidia.com/
NVIDIA_API_KEY="nvapi-your-nvidia-nim-token-here"

# Security (leave blank to disable admin header checks for local dev)
ADMIN_SECRET_KEY=""

# Ingestion targets (comma-separated feed URLs)
DISCOVERY_FEEDS="https://devpost.com/hackathons"
